# Copy to .env and adjust. Never commit .env.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# HTTPS admin / CSRF (comma-separated, include scheme)
# CSRF_TRUSTED_ORIGINS=https://your-api.example.com

# CORS: comma-separated origins (e.g. https://app.example.com,http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL: set DATABASE_URL (Railway injects this when Postgres is linked)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Optional: if Postgres requires explicit SSL from dj-database-url
# DATABASE_SSL_REQUIRE=true

# Optional: HTTPS in production
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
