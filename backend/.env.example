# Copy to `.env` locally (not committed). On Railway, set as variables in the API service.
#
# Stripe — https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_ / pk_test_) until go-live, then sk_live_ / pk_live_.
STRIPE_SECRET_KEY=
# Webhook signing secret for POST /api/webhooks/stripe/ (from Dashboard or `stripe listen`)
STRIPE_WEBHOOK_SECRET=
# Optional. Same as Dashboard “Publishable key”. Exposed in order API when card checkout is on.
STRIPE_PUBLISHABLE_KEY=
# Set true only in dev to POST paid without card when STRIPE_SECRET_KEY is set.
# STRIPE_ALLOW_MANUAL_MARK_PAID=false
#
# Public URL of the browser app (no trailing slash). Used for Stripe Checkout success/cancel and
# password-reset links. If omitted, the same value as DJANGO_PUBLIC_BASE_URL is used (one Railway
# service for SPA + API), then RAILWAY_PUBLIC_DOMAIN, then localhost (with a warning in production).
# FRONTEND_BASE_URL=https://cridorav-production.up.railway.app
#
# DJANGO_PUBLIC_BASE_URL=https://cridorav-production.up.railway.app
