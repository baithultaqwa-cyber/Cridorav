# Copy to .env and adjust. Never commit .env.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# HTTPS admin / CSRF (comma-separated, include scheme)
# CSRF_TRUSTED_ORIGINS=https://your-api.example.com

# CORS: comma-separated origins (e.g. https://app.example.com,http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Railway / Postgres: set by platform when you link PostgreSQL (preferred)
# DATABASE_URL=postgres://...

# Or manual Postgres:
# POSTGRES_DB=cridora
# POSTGRES_USER=cridora
# POSTGRES_PASSWORD=secret
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# Optional: if Postgres requires explicit SSL from dj-database-url
# DATABASE_SSL_REQUIRE=true

# Optional: HTTPS in production
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
