# Vite: copy to `.env` / `.env.local` (not committed). Railway: set on the frontend service.
#
# VITE_API_ORIGIN=https://your-api.example.com
#
# Set `false` when the API has STRIPE_SECRET_KEY so the payment page copy matches card checkout.
# VITE_SIMULATED_PAYMENT=false
#
# Optional. Same `pk_` as Stripe Dashboard. Also returned on order as `stripe_publishable_key` when applicable.
# Not required for server-side Checkout redirect.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_
